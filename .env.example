# ============================================================
#  EFWS — Environment Variables Template
#  Salin file ini:  cp .env.example .env
#  Lalu isi nilai yang sesuai. JANGAN commit file .env ke git!
# ============================================================

# ── Identitas perangkat ──────────────────────────────────────
EFWS_DEVICE_ID=efws-001

# ── Mode operasi ─────────────────────────────────────────────
# "mock"     → testing tanpa hardware
# "hardware" → akses GPIO/I2C + GPS SIM7600E nyata
EFWS_RUN_MODE=mock

# ── REST API (WAJIB diisi) ────────────────────────────────────
# Untuk testing cepat: daftar gratis di https://webhook.site
# Untuk production: URL server backend kamu
EFWS_API_URL=https://webhook.site/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Bearer token (kosongkan jika API tidak pakai auth)
EFWS_API_KEY=

# ── GPS (SIM7600E) ───────────────────────────────────────────
# Koordinat lat/lon diambil OTOMATIS dari GPS modul SIM7600E.
# Isi ini hanya sebagai FALLBACK jika GPS tidak dapat fix.
EFWS_LAT=-1.2654
EFWS_LON=116.8312
# Timeout tunggu GPS fix saat startup (detik, default 90)
EFWS_GPS_TIMEOUT=90
# Seberapa sering refresh koordinat GPS (detik, default 300 = 5 menit)
EFWS_GPS_INTERVAL=300

# ── Timing ───────────────────────────────────────────────────
EFWS_READ_INTERVAL=5          # baca sensor tiap N detik
EFWS_PUBLISH_INTERVAL=10      # kirim ke API tiap N detik

# ── Database ─────────────────────────────────────────────────
# Biarkan kosong untuk pakai path default (database/efws_data.db)
# EFWS_DB_PATH=/home/pi/efws/database/efws_data.db

# ── Jaringan ─────────────────────────────────────────────────
EFWS_APN=internet             # APN SIM card (Telkomsel=internet, XL=internet, dll)
EFWS_VERIFY_SSL=true

# ── Hardware: port serial (hanya saat RUN_MODE=hardware) ─────
EFWS_ANEM_PORT=/dev/ttyUSB0   # anemometer RS485
EFWS_SIM_PORT=/dev/ttyUSB2    # SIM7600 AT commands

# ── Hardware: GPIO/I2C (ubah hanya jika wiring berbeda) ──────
# EFWS_GPIO_FLAME=17
# EFWS_GPIO_RELAY=27
# EFWS_GPIO_BUZZER=22
# EFWS_GPIO_LED=23
# EFWS_BME280_ADDR=0x76
# EFWS_ADS1115_ADDR=0x48
